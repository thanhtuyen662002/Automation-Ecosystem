# =============================================================================
# SECRETS & ENVIRONMENT VARIABLES  ← CRITICAL: Never commit these
# =============================================================================
.env
.env.local
.env.production
.env.staging
.env.development
.env.*.local
!.env.example
!.env.frontend.example

# =============================================================================
