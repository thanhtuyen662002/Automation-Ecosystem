{
  "pythonVersion": "3.11",
  "pythonPlatform": "Windows",
  "typeCheckingMode": "basic",
  "extraPaths": ["."],
  "venvPath": ".",
  "venv": ".venv",
  "reportMissingImports": false,
  "reportMissingModuleSource": false,
  "exclude": [
    "**/node_modules",
    "**/__pycache__",
    "**/build",
    "**/dist",
    "**/backend_dist",
    "**/*.egg-info"
  ]
}
