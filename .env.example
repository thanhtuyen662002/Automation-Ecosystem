DATABASE_URL=postgresql://postgres:postgres@localhost:5432/automation
REDIS_URL=redis://localhost:6379/0
WORKER_ID=worker-1

MAX_BROWSER_WORKERS=1
MAX_MEDIA_WORKERS=2
MAX_AI_WORKERS=4
HEARTBEAT_INTERVAL=30
TASK_TIMEOUT=300
MAX_RETRIES=3

# Optional runtime settings
WORKER_REDIS_STREAM=worker:tasks
WORKER_REDIS_GROUP=worker-runtime
WORKER_READ_BLOCK_MS=5000
WORKER_RETRY_BASE_DELAY_SECONDS=5
WORKER_RETRY_MAX_DELAY_SECONDS=300
WORKER_DEFAULT_POOL=ai
WORKER_TASK_TYPE_POOLS={"render_page":"browser","transcode_video":"media","summarize":"ai"}
WORKER_LOG_LEVEL=INFO
