DATABASE_URL=sqlite+aiosqlite:///{APP_DATA_DIR}/data/app.db
WORKER_ID=desktop-worker-1
API_WORKER_ENABLED=true
WORKER_MAX_CONCURRENCY=4
WORKER_BATCH_SIZE=10
WORKER_POLL_INTERVAL_SECONDS=2
HEARTBEAT_INTERVAL=30
TASK_TIMEOUT=600
WORKER_LEASE_SECONDS=600
WORKER_RETRY_BASE_DELAY_SECONDS=5
WORKER_RETRY_MAX_DELAY_SECONDS=300
WORKER_MAX_PER_TASK_TYPE=2
WORKER_MAX_PER_ACCOUNT=1
WORKER_LOG_LEVEL=INFO
SCHEDULER_INTERVAL_SECONDS=5
PUBLISH_WAIT_APPROVAL_MAX_RETRIES=288

ADSPOWER_API_BASE=http://local.adspower.net:50325
ADSPOWER_API_KEY=
ADSPOWER_OPEN_TIMEOUT_SECONDS=60
ADSPOWER_VERIFY_AFTER_LOGIN=false
BROWSER_DIAGNOSTICS_ENABLED=false

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_jwt_key
LICENSE_API_URL=https://your-project.supabase.co/functions/v1/license-api
LICENSE_OFFLINE_GRACE_DAYS=7
LICENSE_STATUS_CACHE_TTL_SECONDS=30

SUPABASE_KEY=your-publishable-or-anon-key
DRY_RUN=false
# AI providers, API keys, and model routing are managed in Settings -> AI Providers.
USE_AI_CAPTION=false
AI_COST_PER_1K_TOKENS=0.00015

MEDIA_OUTPUT_DIR=./media_output
BGM_DIR=./bgm

TIKTOK_MIN_VIEWS=10000
TIKTOK_MIN_LIKES=500
TIKTOK_MIN_DURATION=15
TIKTOK_MAX_DURATION=180
TIKTOK_TOP_N=5
TIKTOK_YTDLP_FORMAT=bestvideo*+bestaudio/best[ext=mp4]/best
TIKTOK_YTDLP_IMPERSONATE=chrome
TIKTOK_DOWNLOAD_TIMEOUT_SECONDS=120
TIKTOK_SEARCH_MAX_RESULTS=50
TIKTOK_SEARCH_PROVIDER=adspower
TIKTOK_SEARCH_SCROLL_MAX=12
TIKTOK_SEARCH_STAGNANT_LIMIT=3
TIKTOK_SEARCH_REQUIRE_LOGIN=true
TIKTOK_SEARCH_ALLOW_PHOTO=false
TIKTOK_SEARCH_MIN_VIEWS=10000
TIKTOK_SEARCH_MIN_RELEVANCE_SCORE=0.25
TIKTOK_SEARCH_MAX_PER_AUTHOR=3
TIKTOK_SEARCH_VIRAL_BYPASS_VIEWS=300000
TIKTOK_SEARCH_EMPTY_TEXT_WARN_RATIO=0.7
