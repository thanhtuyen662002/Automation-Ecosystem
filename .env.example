DATABASE_URL=postgresql://postgres:postgres@localhost:5432/automation
WORKER_ID=worker-1

WORKER_MAX_CONCURRENCY=4
WORKER_BATCH_SIZE=10
WORKER_POLL_INTERVAL_SECONDS=2
HEARTBEAT_INTERVAL=30
# Raise to 600+ when using remake_video (FFmpeg re-encoding can take several minutes)
TASK_TIMEOUT=600
WORKER_LEASE_SECONDS=600
WORKER_RETRY_BASE_DELAY_SECONDS=5
WORKER_RETRY_MAX_DELAY_SECONDS=300
WORKER_MAX_PER_TASK_TYPE=2
WORKER_MAX_PER_ACCOUNT=1
WORKER_LOG_LEVEL=INFO

# ── TikTok Pipeline ──────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Local directory where downloaded + remixed videos are stored
MEDIA_OUTPUT_DIR=./media_output

# Optional: directory containing royalty-free .mp3 files for BGM overlay
BGM_DIR=./bgm

# Video selection thresholds
TIKTOK_MIN_VIEWS=10000
TIKTOK_MIN_LIKES=500
TIKTOK_MIN_DURATION=15
TIKTOK_MAX_DURATION=180
TIKTOK_TOP_N=5

# Maximum number of yt-dlp search results to evaluate per keyword
TIKTOK_SEARCH_MAX_RESULTS=50
