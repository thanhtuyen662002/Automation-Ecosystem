# Automation Ecosystem environment example
#
# Keep packaged desktop runtime files non-secret. Do not ship service-role keys,
# admin secrets, provider API keys, or shared token secrets in .env.production.

# Local desktop runtime. The packaged app creates this automatically under the
# user's AppData directory when missing.
DATABASE_URL=sqlite+aiosqlite:///{APP_DATA_DIR}/data/app.db
WORKER_ID=desktop-worker-1
WORKER_MAX_CONCURRENCY=4
WORKER_BATCH_SIZE=10
WORKER_POLL_INTERVAL_SECONDS=2
HEARTBEAT_INTERVAL=30
TASK_TIMEOUT=600
WORKER_LEASE_SECONDS=600
WORKER_RETRY_BASE_DELAY_SECONDS=5
WORKER_RETRY_MAX_DELAY_SECONDS=300
WORKER_MAX_PER_TASK_TYPE=2
WORKER_MAX_PER_ACCOUNT=1
WORKER_LOG_LEVEL=INFO
SCHEDULER_INTERVAL_SECONDS=5

# License system for packaged/local app.
# React calls Python localhost; Python calls the trusted Supabase Edge Function.
# Do not ship service-role keys, peppers, salts, or direct DB URLs to users.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_jwt_key
LICENSE_API_URL=https://your-project.supabase.co/functions/v1/license-api
LICENSE_OFFLINE_GRACE_DAYS=7
LICENSE_STATUS_CACHE_TTL_SECONDS=30

# Admin-only license tooling. Keep these on the project owner's machine or in
# Supabase Edge Function secrets only. Never include them in customer releases.
# SUPABASE_SERVICE_ROLE_KEY=sb_secret_or_service_role_key
# LICENSE_KEY_PEPPER=replace-with-random-32-byte-secret
# MACHINE_HASH_PEPPER=replace-with-another-random-32-byte-secret
# SUPABASE_DB_URL=postgresql://postgres:password@db.project-ref.supabase.co:5432/postgres

# Optional: global memory / shared awareness. Use publishable/anon keys only in
# user-distributed apps, with RLS enabled on exposed tables.
SUPABASE_KEY=your-publishable-or-anon-key

# Developer/admin-only values. Use these only on your own machine or in
# Supabase Edge Function secrets. Never ship them to users.
# ADMIN_SECRET=change-me-only-for-local-admin-dev
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=
# HF_API_KEY=

# AI/content generation toggles. If provider keys are yours, proxy these calls
# through Edge Functions instead of exposing keys in the desktop app.
OPENAI_MODEL=gpt-4o
DRY_RUN=false
USE_AI_CAPTION=false
AI_COST_PER_1K_TOKENS=0.00015

MEDIA_OUTPUT_DIR=./media_output
BGM_DIR=./bgm

TIKTOK_MIN_VIEWS=10000
TIKTOK_MIN_LIKES=500
TIKTOK_MIN_DURATION=15
TIKTOK_MAX_DURATION=180
TIKTOK_TOP_N=5
TIKTOK_SEARCH_MAX_RESULTS=50
